# moove コーディング規約に基づく perltidy 設定
# 参照: moovibe/rules/perl.md, 実コード: work/Moove2, work/Tamerume

# インデント
-i=4              # 本体 4 スペース
-ci=4             # 継続行 4 スペース

# 行長
-l=120            # 最大行長

# ブレーススタイル（K&R デフォルト + cuddled else）
# 開き { 同一行はデフォルト動作
-ce               # } else { を同一行に

# 括弧の詰め（内側に空白を入れない: if ($x) / [1,2,3] / {a=>1}）
-pt=2
-sbt=2
-bt=2

# 縦揃えは有効（moove 既存コードに合わせる）
# valign 系オプションはデフォルトのまま
