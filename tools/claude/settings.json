{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "Read",
      "Glob",
      "Grep",
      "LS",
      "Bash",
      "Write",
      "Edit",
      "MultiEdit",
      "Bash(npm run lint)",
      "Bash(npm run test:*)",
      "Read(~/.zshrc)",
      "Read(~/.claude/*)"
    ],
    "deny": [
      "Read(~/.claude/.*)",
      "Bash(terraform destroy)",
      "Bash(terraform apply)"
    ]
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  }
}
